# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=staff_housing
DB_USER=root
DB_PASS=

# Application Configuration
APP_URL=http://localhost/jkuat-housing-portal/
APP_ENV=development

# Gmail SMTP Configuration (Optional - for email features)
# To enable email notifications:
# 1. Generate a Gmail App Password: https://myaccount.google.com/apppasswords
# 2. Replace SMTP_USER with your email
# 3. Replace SMTP_PASS with your Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_SECURE=tls

# From address for emails
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME="JKUAT Housing Portal"

# Optional: Sentry Error Tracking (leave empty if not using)
SENTRY_DSN=
